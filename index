<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CV - Bastien Goodall</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      @page {
        size: A4;
        margin: 0;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --ink: #0c0c0f;
        --ink-90: #1a1a22;
        --ink-80: #2a2a35;
        --ink-60: #52526a;
        --ink-40: #8888a0;
        --ink-20: #c4c4d4;
        --ink-10: #e8e8f0;
        --ink-05: #f4f4f8;
        --paper: #fafaf9;
        --accent: #d4a853;
        --accent-dim: #b8923f;
        --accent-glow: rgba(212, 168, 83, 0.12);
        --accent-bright: #e8c06a;
        --cyan: #4ecdc4;
        --cyan-dim: rgba(78, 205, 196, 0.1);
        --green: #22c55e;
        --green-dim: rgba(34, 197, 94, 0.1);
        --indigo: #6366f1;
        --indigo-dim: rgba(99, 102, 241, 0.1);
        --rose: #f43f5e;
        --rose-dim: rgba(244, 63, 94, 0.1);
      }

      body {
        font-family: "Outfit", sans-serif;
        color: var(--ink);
        background: #e4e4e8;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      @media print {
        body {
          background: white;
          margin: 0;
          padding: 0;
        }
        .page {
          margin: 0;
          box-shadow: none;
          max-height: 297mm;
          overflow: hidden;
        }
        .page,
        .page * {
          page-break-inside: avoid;
        }
        .grain::before {
          display: none;
        }
      }

      .page {
        width: 210mm;
        height: 297mm;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 72mm 1fr;
        overflow: hidden;
        position: relative;
        box-shadow:
          0 4px 6px rgba(0, 0, 0, 0.05),
          0 20px 40px rgba(0, 0, 0, 0.1),
          0 40px 80px rgba(0, 0, 0, 0.08);
      }

      .panel-left {
        background: var(--ink);
        color: var(--ink-20);
        padding: 0;
        position: relative;
        overflow: hidden;
      }

      .panel-left::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 1;
      }

      .panel-left::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 3px;
        height: 100%;
        background: linear-gradient(
          to bottom,
          transparent 0%,
          var(--accent) 15%,
          var(--accent) 35%,
          transparent 50%,
          var(--accent-dim) 70%,
          transparent 100%
        );
        z-index: 2;
      }

      .panel-left-inner {
        position: relative;
        z-index: 3;
        padding: 30px 18px 24px;
        display: flex;
        flex-direction: column;
        height: 100%;
      }

      .identity {
        text-align: center;
        margin-bottom: 26px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--ink-80);
      }

      .avatar {
        width: 82px;
        height: 82px;
        border-radius: 50%;
        margin: 0 auto 14px;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .avatar::before {
        content: "";
        position: absolute;
        inset: -3px;
        border-radius: 50%;
        border: 1.5px solid var(--accent);
        opacity: 0.6;
      }

      .avatar-inner {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        overflow: hidden;
        background: var(--ink-80);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .avatar-inner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .avatar-monogram {
        font-family: "Syne", sans-serif;
        font-size: 26px;
        font-weight: 800;
        color: var(--accent);
        letter-spacing: -1px;
      }

      .identity-role {
        font-family: "JetBrains Mono", monospace;
        font-size: 7.5px;
        font-weight: 500;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 2.5px;
        margin-top: 2px;
      }

      .side-section {
        margin-bottom: 20px;
      }

      .side-label {
        font-family: "Syne", sans-serif;
        font-size: 8px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--accent);
        margin-bottom: 12px;
        position: relative;
        padding-left: 14px;
      }

      .side-label::before {
        content: "";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 6px;
        height: 1px;
        background: var(--accent);
      }

      .contact-item {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 9px;
        font-size: 8px;
        color: var(--ink-20);
        line-height: 1.3;
      }

      .contact-icon {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        background: var(--ink-80);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .contact-icon svg {
        width: 11px;
        height: 11px;
        fill: var(--accent);
        opacity: 0.8;
      }

      .skill-group {
        margin-bottom: 10px;
      }

      .skill-group-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 6.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--ink-40);
        margin-bottom: 6px;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
      }

      .tag {
        font-family: "JetBrains Mono", monospace;
        font-size: 7px;
        font-weight: 500;
        padding: 3px 8px;
        border-radius: 3px;
        border: 1px solid var(--ink-80);
        color: var(--ink-20);
        background: transparent;
      }

      .tag--accent {
        border-color: rgba(212, 168, 83, 0.3);
        color: var(--accent-bright);
        background: rgba(212, 168, 83, 0.06);
      }

      .tag--cyan {
        border-color: rgba(78, 205, 196, 0.25);
        color: var(--cyan);
        background: rgba(78, 205, 196, 0.05);
      }

      .tag--green {
        border-color: rgba(34, 197, 94, 0.25);
        color: var(--green);
        background: rgba(34, 197, 94, 0.05);
      }

      .tag--indigo {
        border-color: rgba(99, 102, 241, 0.25);
        color: var(--indigo);
        background: rgba(99, 102, 241, 0.05);
      }

      .tag--rose {
        border-color: rgba(244, 63, 94, 0.25);
        color: var(--rose);
        background: rgba(244, 63, 94, 0.05);
      }

      .soft-item {
        font-size: 8px;
        color: var(--ink-20);
        margin-bottom: 6px;
        padding-left: 12px;
        position: relative;
        line-height: 1.4;
      }

      .soft-item::before {
        content: "";
        position: absolute;
        left: 0;
        top: 5px;
        width: 5px;
        height: 1px;
        background: var(--accent-dim);
      }

      .lang-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
        font-size: 8.5px;
      }

      .lang-name {
        color: var(--ink-20);
      }

      .lang-badge {
        font-family: "JetBrains Mono", monospace;
        font-size: 7px;
        font-weight: 500;
        padding: 2px 8px;
        border-radius: 2px;
        background: rgba(212, 168, 83, 0.1);
        color: var(--accent);
        letter-spacing: 0.5px;
      }

      .panel-right {
        background: var(--paper);
        position: relative;
        overflow: hidden;
      }

      .panel-right::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.015'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 1;
      }

      .panel-right-inner {
        position: relative;
        z-index: 2;
        padding: 30px 28px 24px 26px;
        display: flex;
        flex-direction: column;
        height: 100%;
      }

      .header {
        margin-bottom: 22px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--ink-10);
        position: relative;
      }

      .header::after {
        content: "";
        position: absolute;
        bottom: -1px;
        left: 0;
        width: 60px;
        height: 2px;
        background: var(--accent);
      }

      .header-name {
        font-family: "Syne", sans-serif;
        font-size: 32px;
        font-weight: 800;
        color: var(--ink);
        line-height: 1;
        letter-spacing: -1px;
        margin-bottom: 2px;
      }

      .header-name span {
        color: var(--accent-dim);
      }

      .header-tagline {
        font-family: "JetBrains Mono", monospace;
        font-size: 9px;
        font-weight: 500;
        color: var(--ink-60);
        letter-spacing: 0.5px;
        margin-top: 6px;
      }

      .header-bio {
        font-size: 8.5px;
        color: var(--ink-60);
        line-height: 1.65;
        margin-top: 10px;
        max-width: 98%;
      }

      .header-pills {
        display: flex;
        gap: 6px;
        margin-top: 12px;
      }

      .pill {
        font-family: "JetBrains Mono", monospace;
        font-size: 7px;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 2px;
        letter-spacing: 0.3px;
      }

      .pill--gold {
        background: var(--accent-glow);
        color: var(--accent-dim);
        border: 1px solid rgba(212, 168, 83, 0.2);
      }

      .pill--dark {
        background: var(--ink);
        color: var(--ink-20);
      }

      .pill--outline {
        background: transparent;
        color: var(--ink-60);
        border: 1px solid var(--ink-10);
      }

      .section {
        margin-bottom: 18px;
      }

      .section-heading {
        font-family: "Syne", sans-serif;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--ink);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .section-heading::after {
        content: "";
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, var(--ink-10), transparent);
      }

      .project {
        padding: 14px 16px;
        margin-bottom: 10px;
        border-radius: 6px;
        position: relative;
        border: 1px solid var(--ink-10);
        background: white;
      }

      .project::before {
        content: "";
        position: absolute;
        left: 0;
        top: 12px;
        bottom: 12px;
        width: 3px;
        border-radius: 0 3px 3px 0;
      }

      .project--gold::before {
        background: var(--accent);
      }
      .project--cyan::before {
        background: var(--cyan);
      }

      .project-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
      }

      .project-title {
        font-family: "Syne", sans-serif;
        font-size: 12px;
        font-weight: 700;
        color: var(--ink);
      }

      .project-badge {
        font-family: "JetBrains Mono", monospace;
        font-size: 6.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 3px 10px;
        border-radius: 2px;
      }

      .project-badge--perso {
        background: var(--green-dim);
        color: var(--green);
        border: 1px solid rgba(34, 197, 94, 0.15);
      }

      .project-badge--sco {
        background: var(--cyan-dim);
        color: var(--cyan);
        border: 1px solid rgba(78, 205, 196, 0.15);
      }

      .project-desc {
        font-size: 8.5px;
        color: var(--ink-60);
        line-height: 1.55;
        margin-bottom: 8px;
      }

      .project-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 6px;
      }

      .project-stack span {
        font-family: "JetBrains Mono", monospace;
        font-size: 6.5px;
        font-weight: 500;
        padding: 2.5px 7px;
        border-radius: 2px;
        background: var(--ink-05);
        color: var(--ink-60);
        border: 1px solid var(--ink-10);
      }

      .tl-item {
        position: relative;
        padding-left: 16px;
        margin-bottom: 14px;
      }

      .tl-item::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: -14px;
        width: 1px;
        background: var(--ink-10);
      }

      .tl-item:last-child::before {
        bottom: 0;
      }

      .tl-item::after {
        content: "";
        position: absolute;
        left: -3px;
        top: 5px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        border: 1.5px solid var(--accent);
        background: var(--paper);
      }

      .tl-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2px;
      }

      .tl-role {
        font-family: "Syne", sans-serif;
        font-size: 10.5px;
        font-weight: 700;
        color: var(--ink);
      }

      .tl-date {
        font-family: "JetBrains Mono", monospace;
        font-size: 7px;
        font-weight: 500;
        color: var(--accent-dim);
        background: var(--accent-glow);
        padding: 2px 8px;
        border-radius: 2px;
        white-space: nowrap;
        flex-shrink: 0;
        letter-spacing: 0.3px;
      }

      .tl-place {
        font-size: 8.5px;
        color: var(--ink-40);
        font-weight: 500;
        margin-bottom: 4px;
      }

      .tl-bullets {
        list-style: none;
      }

      .tl-bullets li {
        font-size: 8px;
        color: var(--ink-60);
        padding-left: 10px;
        position: relative;
        line-height: 1.55;
        margin-bottom: 2px;
      }

      .tl-bullets li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 5px;
        width: 4px;
        height: 1px;
        background: var(--accent);
      }

      .edu-item {
        margin-bottom: 10px;
      }

      .edu-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2px;
      }

      .edu-year {
        font-family: "JetBrains Mono", monospace;
        font-size: 7px;
        font-weight: 500;
        color: var(--accent-dim);
        background: var(--accent-glow);
        padding: 2px 8px;
        border-radius: 2px;
        white-space: nowrap;
        flex-shrink: 0;
        letter-spacing: 0.3px;
      }

      .edu-title {
        font-family: "Syne", sans-serif;
        font-size: 10px;
        font-weight: 700;
        color: var(--ink);
        line-height: 1.2;
      }

      .edu-school {
        font-size: 8px;
        color: var(--ink-40);
        margin-top: 1px;
      }

      .edu-detail {
        font-size: 7.5px;
        color: var(--ink-60);
        margin-top: 2px;
        line-height: 1.4;
      }

      .card-grid {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .card {
        flex: 1;
        min-width: 120px;
        background: white;
        border: 1px solid var(--ink-10);
        border-radius: 6px;
        padding: 10px 12px;
        position: relative;
      }

      .card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 10px;
        bottom: 10px;
        width: 3px;
        border-radius: 0 3px 3px 0;
      }

      .card--indigo::before {
        background: var(--indigo);
      }

      .card--rose::before {
        background: var(--rose);
      }

      .card-title {
        font-family: "Syne", sans-serif;
        font-size: 9.5px;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 4px;
      }

      .card-desc {
        font-size: 7.5px;
        color: var(--ink-60);
      }

      .card-tags {
        display: flex;
        gap: 4px;
        margin-top: 6px;
        flex-wrap: wrap;
      }

      .card-tag {
        font-family: "JetBrains Mono", monospace;
        font-size: 6px;
        padding: 2px 6px;
        border-radius: 2px;
        background: var(--ink-05);
        color: var(--ink-60);
        border: 1px solid var(--ink-10);
      }

      .qrcode-wrapper {
        margin: 0 0 20px 0;
        display: flex;
        justify-content: center;
      }

      .qrcode-wrapper img {
        width: 130px;
        height: 130px;
        padding: 6px;
        background: #ffffff;
        border-radius: 8px;
        border: 1px solid var(--ink-80);
        display: block;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="panel-left">
        <div class="panel-left-inner">
          <div class="identity">
            <div class="avatar">
              <div class="avatar-inner">
                <img
                  src="moi.png"
                  alt="Bastien Goodall"
                  onerror="
                    this.style.display = 'none';
                    this.parentElement.innerHTML =
                      '<div class=\'avatar-monogram\'>BG</div>';
                  "
                />
              </div>
            </div>
            <div class="identity-role">Développeur Fullstack</div>
          </div>

          <div class="side-section">
            <div class="side-label">Contact</div>

            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                  />
                </svg>
              </div>
